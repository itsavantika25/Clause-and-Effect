rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
function isAdmin() {
  return isAuthenticated() &&
    request.auth.token.email_verified == true &&
    request.auth.token.email in [
      "avantika.agarwal2505@gmail.com",
      "clause.and.effect57@gmail.com",
      "ridhimakhanna2001@gmail.com",
      "aseeskauroberoi@gmail.com"
    ];
}

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 &&
             data.status in ['draft', 'published'];
    }

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
